            <instance_controller url="#petArmat_body-skin">
              <skeleton>#petArmat_hips</skeleton>
              <bind_material>
                <technique_common>
                  <instance_material symbol="dog-material" target="#dog-material">
                    <bind_vertex_input semantic="UVMap" input_semantic="TEXCOORD" input_set="0"/>
                  </instance_material>
                </technique_common>
              </bind_material>
            </instance_controller>
          </node>
          <extra>
            <technique profile="blender">
              <collections sid="collections" type="string">Bones</collections>
              <visible_collections sid="visible_collections" type="string">Bones</visible_collections>
              <active_collection sid="active_collection" type="string">Bones</active_collection>
            </technique>
          </extra>
        </node>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>